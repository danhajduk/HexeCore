{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Catalog of Core-owned schemas generated from app.api.addons_registry.",
  "schemas": {
    "ConfigureAddonRequest": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "config": {
          "additionalProperties": true,
          "title": "Config",
          "type": "object"
        }
      },
      "title": "ConfigureAddonRequest",
      "type": "object"
    },
    "RegisterAddonRequest": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "base_url": {
          "minLength": 1,
          "title": "Base Url",
          "type": "string"
        },
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Name"
        },
        "ui_base_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ui Base Url"
        },
        "ui_enabled": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ui Enabled"
        },
        "ui_mode": {
          "anyOf": [
            {
              "enum": [
                "spa",
                "server"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ui Mode"
        },
        "version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Version"
        }
      },
      "required": [
        "base_url"
      ],
      "title": "RegisterAddonRequest",
      "type": "object"
    }
  },
  "title": "Hexe Addons Registry API Request Models",
  "type": "object"
}
