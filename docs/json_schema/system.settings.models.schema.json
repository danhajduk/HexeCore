        "platform_name",
        "platform_short",
        "platform_domain",
        "core_name",
        "supervisor_name",
        "nodes_name",
        "addons_name",
        "docs_name",
        "legacy_internal_namespace",
        "legacy_compatibility_note",
        "public_hostname",
        "public_ui_hostname",
        "public_api_hostname"
