        },
        "core_id": {
          "title": "Core Id",
          "type": "string"
        },
        "core_name": {
          "title": "Core Name",
          "type": "string"
        },
        "docs_name": {
          "title": "Docs Name",
          "type": "string"
        },
        "legacy_compatibility_note": {
          "title": "Legacy Compatibility Note",
          "type": "string"
        },
        "legacy_internal_namespace": {
          "title": "Legacy Internal Namespace",
          "type": "string"
        },
        "nodes_name": {
          "title": "Nodes Name",
          "type": "string"
        },
        "ok": {
          "default": true,
          "title": "Ok",
          "type": "boolean"
        },
        "platform_domain": {
          "title": "Platform Domain",
          "type": "string"
        },
        "platform_name": {
          "title": "Platform Name",
          "type": "string"
        },
        "platform_short": {
          "title": "Platform Short",
          "type": "string"
