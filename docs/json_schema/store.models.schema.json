{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Catalog of Core-owned schemas generated from app.store.models.",
  "schemas": {
    "AddonManifest": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "conflicts": {
          "items": {
            "type": "string"
          },
          "title": "Conflicts",
          "type": "array"
        },
        "core_max_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Core Max Version"
        },
        "core_min_version": {
          "minLength": 1,
          "title": "Core Min Version",
          "type": "string"
        },
        "dependencies": {
          "items": {
            "type": "string"
          },
          "title": "Dependencies",
          "type": "array"
        },
        "id": {
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "permissions": {
          "items": {
            "enum": [
              "filesystem.read",
              "filesystem.write",
              "network.egress",
              "network.ingress",
              "process.spawn",
              "system.metrics.read",
              "mqtt.publish",
              "mqtt.subscribe"
            ],
            "type": "string"
          },
          "title": "Permissions",
          "type": "array"
        },
        "publisher_id": {
          "minLength": 1,
          "title": "Publisher Id",
          "type": "string"
        },
        "version": {
          "minLength": 1,
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "id",
        "name",
        "version",
        "core_min_version",
        "dependencies",
        "conflicts",
        "publisher_id",
        "permissions"
      ],
      "title": "AddonManifest",
      "type": "object"
    },
    "CompatibilitySpec": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
