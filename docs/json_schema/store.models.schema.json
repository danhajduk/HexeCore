          "type": "string"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "package_profile": {
          "default": "embedded_addon",
          "enum": [
            "embedded_addon",
            "standalone_service"
          ],
          "title": "Package Profile",
          "type": "string"
        },
        "permissions": {
          "items": {
            "enum": [
              "filesystem.read",
              "filesystem.write",
              "network.egress",
              "network.ingress",
              "process.spawn",
              "system.metrics.read",
              "mqtt.publish",
              "mqtt.subscribe"
            ],
            "type": "string"
          },
          "title": "Permissions",
          "type": "array"
        },
        "publisher_id": {
          "minLength": 1,
          "title": "Publisher Id",
          "type": "string"
        },
        "runtime_defaults": {
          "anyOf": [
            {
              "$ref": "#/$defs/RuntimeDefaults"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "signature": {
          "$ref": "#/$defs/SignatureBlock"
        },
        "version": {
          "minLength": 1,
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "id",
        "name",
        "version",
        "core_min_version",
        "dependencies",
        "conflicts",
        "checksum",
        "publisher_id",
        "permissions",
        "compatibility"
      ],
